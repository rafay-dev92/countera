{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "useUnknownInCatchVariables": false
  },
  "include": ["**/*.js", "**/*.ts"],
  "exclude": ["node_modules", "uploads", "backups", "logs", "dist"]
}
